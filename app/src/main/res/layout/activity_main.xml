<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ══════════════════════════════════════════════════
         PICKER SCREEN  (visible when STOPPED)
         ══════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/pickerContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <NumberPicker
            android:id="@+id/pickerHours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"
            android:layout_marginEnd="24dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="140dp"
            android:background="#E0E0E0"
            android:layout_marginEnd="24dp"/>

        <NumberPicker
            android:id="@+id/pickerMinutes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"
            android:layout_marginEnd="24dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="140dp"
            android:background="#E0E0E0"
            android:layout_marginEnd="24dp"/>

        <NumberPicker
            android:id="@+id/pickerSeconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════
         RUNNING SCREEN  (visible when RUNNING / PAUSED)
         ══════════════════════════════════════════════════ -->

    <com.yor.timer.TimerRingView
        android:id="@+id/timerRingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:contentDescription="@string/timer_default"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.85"/>

    <!-- FIX: android:text uses @string resource instead of hardcoded "00:00:00" -->
    <TextView
        android:id="@+id/tvTimerDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/timer_default"
        android:textColor="#1A1A1A"
        android:textSize="52sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.05"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/timerRingView"
        app:layout_constraintBottom_toTopOf="@id/tvTotalTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.55"/>

    <!-- FIX: android:text uses @string resource instead of hardcoded "Total 0 seconds" -->
    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/timer_total_default"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTimerDisplay"
        app:layout_constraintBottom_toBottomOf="@id/timerRingView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══════════════════════════════════════════════════
         BOTTOM CONTROLS  (always visible)
         ══════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="52dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Stop button: visible while RUNNING/PAUSED; invisible when STOPPED -->
        <!-- FIX: android:contentDescription added — fixes "No speakable text" error -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopReset"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="40dp"
            android:backgroundTint="#EBEBEB"
            android:visibility="invisible"
            android:contentDescription="@string/btn_stop_desc"
            app:cornerRadius="36dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_media_previous"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="#3C4043" />

        <!-- Play / Pause button: always visible -->
        <!-- FIX: android:contentDescription added — fixes "No speakable text" error -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:backgroundTint="#FFFFFF"
            android:contentDescription="@string/btn_play_desc"
            app:cornerRadius="44dp"
            app:elevation="8dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="40dp"
            app:iconTint="#1A73E8" />

        <!-- Sound / settings: shown when STOPPED; invisible while RUNNING -->
        <!-- FIX: android:contentDescription added — fixes "No speakable text" error -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoundSettings"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="40dp"
            android:backgroundTint="#EBEBEB"
            android:contentDescription="@string/btn_sound_desc"
            app:cornerRadius="36dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_lock_silent_mode_off"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="26dp"
            app:iconTint="#5F6368" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>