<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">


    <TextView
        android:id="@+id/tvTimerDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="#000000"
        android:textSize="72sp"
        android:fontFamily="sans-serif-light"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/pickerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <NumberPicker
            android:id="@+id/pickerHours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"
            android:layout_marginEnd="24dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="140dp"
            android:background="#E0E0E0"
            android:layout_marginEnd="24dp"/>

        <NumberPicker
            android:id="@+id/pickerMinutes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"
            android:layout_marginEnd="24dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="140dp"
            android:background="#E0E0E0"
            android:layout_marginEnd="24dp"/>

        <NumberPicker
            android:id="@+id/pickerSeconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1.4"
            android:scaleY="1.4"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoundSettings"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="48dp"
            android:backgroundTint="#F1F3F4"
            app:cornerRadius="32dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_lock_silent_mode_off"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="#5F6368" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="44dp"
            app:elevation="6dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="40dp"
            app:iconTint="#1A73E8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnList"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="48dp"
            android:backgroundTint="#F1F3F4"
            app:cornerRadius="32dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="#5F6368" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>